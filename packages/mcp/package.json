{
  "name": "@upstash/context7-mcp",
  "version": "3.2.4",
  "mcpName": "io.github.upstash/context7",
  "description": "MCP server for Context7",
  "scripts": {
    "build": "tsc && node -e \"if (process.platform !== 'win32') require('fs').chmodSync('dist/index.js', 0o755)\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:check": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "tsc --watch",
    "prewarm": "node dist/prewarm.js",
    "migrate:index": "node dist/migrate-index.js",
    "evaluate:retrieval": "node dist/evaluate-retrieval.js",
    "start": "node dist/index.js --transport http",
    "pack-mcpb": "pnpm install && pnpm run build && rm -rf node_modules && pnpm install --prod && cp mcpb/manifest.json manifest.json && cp mcpb/.mcpbignore .mcpbignore && cp ../../public/icon.png icon.png && mcpb validate manifest.json && mcpb pack . mcpb/context7.mcpb && rm manifest.json .mcpbignore icon.png && pnpm install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/upstash/context7.git",
    "directory": "packages/mcp"
  },
  "keywords": [
    "modelcontextprotocol",
    "mcp",
    "context7",
    "vibe-coding",
    "developer tools",
    "documentation",
    "context"
  ],
  "author": "abdush",
  "license": "MIT",
  "type": "module",
  "bin": {
    "context7-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "bugs": {
    "url": "https://github.com/upstash/context7/issues"
  },
  "homepage": "https://github.com/upstash/context7#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@neuledge/context": "1.2.0",
    "better-sqlite3": "12.11.1",
    "commander": "15.0.0",
    "express": "5.2.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "26.1.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
